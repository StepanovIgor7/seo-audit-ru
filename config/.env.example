# Yandex Wordstat API token (required for /yandex-wordstat)
# Получить: https://yandex.ru/support2/wordstat/ru/content/api-wordstat
YANDEX_WORDSTAT_TOKEN=your_wordstat_token_here

# Yandex Webmaster API token (required for /yandex-webmaster)
# Получить: https://oauth.yandex.ru/
YANDEX_WEBMASTER_TOKEN=your_webmaster_token_here

# Google PageSpeed API key (optional, for Core Web Vitals data)
# Получить: https://console.cloud.google.com/ → APIs → PageSpeed Insights API
# PAGESPEED_API_KEY=your_pagespeed_key_here
